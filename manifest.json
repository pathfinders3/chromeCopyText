{
  "manifest_version": 3,
  "name": "Ctrl Click Paragraph Copier",
  "version": "1.0",
  "description": "Ctrl + Click으로 단락/줄 텍스트를 클립보드에 복사합니다.",
  "permissions": ["clipboardWrite", "clipboardRead", "storage"],
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "set-copy-mode-tag": {
      "suggested_key": {
        "default": "Alt+1"
      },
      "description": "복사 기준: 태그(p/div/li)"
    },
    "set-copy-mode-sentence": {
      "suggested_key": {
        "default": "Alt+2"
      },
      "description": "복사 기준: 문장"
    },
    "open-options-page": {
      "suggested_key": {
        "default": "Alt+0"
      },
      "description": "옵션 페이지 열기"
    },
    "set-copy-mode-date": {
      "suggested_key": {
        "default": "Alt+4"
      },
      "description": "복사 기준: 날짜"
    }
  },
  
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}

